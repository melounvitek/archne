#!/usr/bin/env bash
# Smart focus script: navigates within groups when possible, otherwise moves focus between windows
# Usage: smart-focus <direction>  (l = left, r = right)

direction=$1

if [[ -z "$direction" ]]; then
    echo "Usage: smart-focus <l|r>"
    exit 1
fi

window_info=$(hyprctl activewindow -j)
grouped=$(echo "$window_info" | jq -r '.grouped // []')
address=$(echo "$window_info" | jq -r '.address')

# If not in a group, just movefocus
if [[ "$grouped" == "[]" || "$grouped" == "null" ]]; then
    hyprctl dispatch movefocus "$direction"
    exit 0
fi

# In a group - find current position
mapfile -t members < <(echo "$grouped" | jq -r '.[]')
num_members=${#members[@]}
pos=-1

for i in "${!members[@]}"; do
    if [[ "${members[$i]}" == "$address" ]]; then
        pos=$i
        break
    fi
done

# Fallback if position not found
if [[ $pos -eq -1 ]]; then
    hyprctl dispatch movefocus "$direction"
    exit 0
fi

if [[ "$direction" == "l" ]]; then
    if [[ $pos -gt 0 ]]; then
        # Not at start, navigate within group (backward)
        hyprctl dispatch changegroupactive b
    else
        # At start of group, move focus out
        hyprctl dispatch movefocus l
    fi
elif [[ "$direction" == "r" ]]; then
    if [[ $pos -lt $((num_members - 1)) ]]; then
        # Not at end, navigate within group (forward)
        hyprctl dispatch changegroupactive f
    else
        # At end of group, move focus out
        hyprctl dispatch movefocus r
    fi
else
    # Unknown direction, just pass through
    hyprctl dispatch movefocus "$direction"
fi
